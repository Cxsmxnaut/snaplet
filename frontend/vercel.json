{
  "routes": [
    { "src": "/api/questions/([^/]+)", "dest": "/api/questions/[id].ts?id=$1" },
    { "src": "/api/sessions/([^/]+)/attempts", "dest": "/api/sessions/[id]/attempts.ts?id=$1" },
    { "src": "/api/sources/([^/]+)/questions", "dest": "/api/sources/[id]/questions.ts?id=$1" },
    { "src": "/api/sources/([^/]+)/duplicate", "dest": "/api/sources/[id]/duplicate.ts?id=$1" },
    { "src": "/api/sources/([^/]+)/generate", "dest": "/api/sources/[id]/generate.ts?id=$1" },
    { "src": "/api/sources/([^/]+)", "dest": "/api/sources/[id].ts?id=$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
