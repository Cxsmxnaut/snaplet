# Browser auth configuration.
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_PUBLIC_ANON_KEY"

# Server/runtime auth configuration.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_PUBLIC_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"

# Local site and proxy configuration.
NEXT_PUBLIC_SITE_URL="http://localhost:5173"
VITE_PROXY_TARGET="http://localhost:3000"
# Optional explicit API override instead of the Vite proxy:
# VITE_API_BASE_URL="http://localhost:3000"

# Explicit local-only escape hatches. Leave these OFF in real environments.
# SNAPLET_ALLOW_DEV_USER_OVERRIDE="true"
# SNAPLET_ENABLE_FILE_STATE_FALLBACK="true"

# Generation and answer-check providers.
OLLAMA_API_KEY="YOUR_OLLAMA_API_KEY"
OLLAMA_BASE_URL="https://ollama.com/api"
OLLAMA_MODEL="gemma3:4b"
GROQ_API_KEYS="YOUR_GROQ_KEY"
OPENROUTER_API_KEYS="YOUR_OPENROUTER_KEY"
ANSWER_CHECK_PROVIDERS="ollama,groq,openrouter"
GROQ_ANSWER_CHECK_MODEL="llama-3.1-8b-instant"
OPENROUTER_ANSWER_CHECK_MODEL="openai/gpt-4o-mini"
SEMANTIC_ANSWER_MIN_CONFIDENCE="0.64"
SEMANTIC_ANSWER_TIMEOUT_MS="2800"
# SEMANTIC_ANSWER_LOGGING="failures"
# OLLAMA_LOGGING="silent"

# Extraction helpers.
OCR_SPACE_API_KEY="YOUR_OCR_SPACE_KEY"
